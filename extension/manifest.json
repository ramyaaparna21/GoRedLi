{
  "manifest_version": 3,
  "name": "rRed — Redirects for your team",
  "version": "1.0.0",
  "description": "Create short redirects (r/alias) that resolve to real URLs. Organize redirects in workspaces with your team.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://r/*",
    "https://*.cloudfront.net/*",
    "https://5y6ipnxedldrokeygz3ylosjyu0wbrpf.lambda-url.us-east-1.on.aws/*",
    "https://oauth2.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "rRed",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rred@rred",
      "strict_min_version": "109.0"
    }
  }
}
