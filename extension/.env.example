# Lambda function URL (from terraform output api_url)
API_URL=https://xxxxxx.lambda-url.us-east-1.on.aws

# CloudFront URL (from terraform output admin_app_url)
ADMIN_APP_URL=https://xxxxxx.cloudfront.net

# Google OAuth client ID (same value used in terraform.tfvars)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
