# Required — the build will fail if any of these are missing.
# Copy this file to .env and fill in the real values.

# API URL (custom domain pointing to Lambda function URL)
API_URL=https://api.rred.me

# Admin web app URL (custom domain pointing to CloudFront)
ADMIN_APP_URL=https://rred.me

# Google OAuth client ID (same value used in infra/terraform.tfvars)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Google OAuth client secret (from Google Cloud Console)
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
